<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.uav.mapper.UavMapper">

    <!-- MyBatis SQL 映射文件，定义 UavMapper 接口对应的 7 条 SQL -->
    <!-- 包含：结果映射（UavResultMap）、可复用列列表（Base_Column_List） -->
    <!-- 查询类：selectList（条件分页）、selectById（按ID）、selectByUavCode（按编号，不过滤已删除） -->
    <!-- 增删改：insert（新增，回填自增ID）、updateById（动态更新非null字段）、deleteById（逻辑删除）、physicalDeleteById（物理删除） -->

    <!-- 结果映射：数据库列名（下划线）→ Java 字段名（驼峰） -->
    <resultMap id="UavResultMap" type="com.example.uav.domain.entity.Uav">
        <id     column="id"              property="id"/>
        <result column="uav_code"        property="uavCode"/>
        <result column="model"           property="model"/>
        <result column="manufacturer"    property="manufacturer"/>
        <result column="max_payload"     property="maxPayload"/>
        <result column="max_altitude"    property="maxAltitude"/>
        <result column="max_flight_time" property="maxFlightTime"/>
        <result column="max_speed"       property="maxSpeed"/>
        <result column="wingspan"        property="wingspan"/>
        <result column="weight"          property="weight"/>
        <result column="status"          property="status"/>
        <result column="remark"          property="remark"/>
        <result column="ai_generated"    property="aiGenerated"/>
        <result column="created_at"      property="createdAt"/>
        <result column="updated_at"      property="updatedAt"/>
        <result column="deleted"         property="deleted"/>
    </resultMap>

    <!-- 查询列列表（复用） -->
    <sql id="Base_Column_List">
        id, uav_code, model, manufacturer, max_payload, max_altitude, max_flight_time,
        max_speed, wingspan, weight, status, remark, ai_generated, created_at, updated_at, deleted
    </sql>

    <!-- 按条件分页查询（兼容 MySQL 和 SQLite） -->
    <select id="selectList" parameterType="com.example.uav.domain.query.UavQuery" resultMap="UavResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_uav
        WHERE deleted = 0
        <if test="model != null and model != ''">
            <choose>
                <when test="_databaseId == 'mysql'">
                    AND model LIKE CONCAT('%', #{model}, '%')
                </when>
                <when test="_databaseId == 'sqlite' or _databaseId == 'h2'">
                    AND model LIKE '%' || #{model} || '%'
                </when>
                <otherwise>
                    AND model LIKE '%' || #{model} || '%'
                </otherwise>
            </choose>
        </if>
        <if test="uavCode != null and uavCode != ''">
            AND uav_code = #{uavCode}
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY created_at DESC
    </select>

    <!-- 根据 ID 查询单条无人机信息 -->
    <select id="selectById" resultMap="UavResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_uav
        WHERE id = #{id} AND deleted = 0
    </select>

    <!-- 根据注册编号查询无人机（用于唯一性校验） -->
    <select id="selectByUavCode" resultMap="UavResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_uav
        WHERE uav_code = #{uavCode}
    </select>

    <!-- 新增无人机记录 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO t_uav (uav_code, model, manufacturer, max_payload, max_altitude,
            max_flight_time, max_speed, wingspan, weight, status, remark, ai_generated,
            created_at, updated_at, deleted) VALUES
            (#{uavCode}, #{model}, #{manufacturer}, #{maxPayload}, #{maxAltitude},
            #{maxFlightTime}, #{maxSpeed}, #{wingspan}, #{weight}, #{status,jdbcType=INTEGER},
            #{remark}, #{aiGenerated,jdbcType=INTEGER},
            #{createdAt}, #{updatedAt}, 0)
    </insert>

    <!-- 逻辑删除无人机 -->
    <update id="deleteById">
        UPDATE t_uav SET deleted = 1, updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id} AND deleted = 0
    </update>

    <!-- 批量逻辑删除（单条 SQL，消除 N+1 查询和并发竞态） -->
    <update id="batchDeleteByIds">
        UPDATE t_uav SET deleted = 1, updated_at = CURRENT_TIMESTAMP
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
        AND deleted = 0
    </update>

    <!-- 物理删除无人机（彻底移除记录，用于释放唯一索引） -->
    <delete id="physicalDeleteById">
        DELETE FROM t_uav WHERE id = #{id}
    </delete>

    <!-- 动态更新（只更新非 null 字段） -->
    <update id="updateById" parameterType="com.example.uav.domain.entity.Uav">
        UPDATE t_uav
        <set>
            <if test="model != null and model != ''">model = #{model},</if>
            <if test="manufacturer != null">manufacturer = #{manufacturer},</if>
            <if test="maxPayload != null">max_payload = #{maxPayload},</if>
            <if test="maxAltitude != null">max_altitude = #{maxAltitude},</if>
            <if test="maxFlightTime != null">max_flight_time = #{maxFlightTime},</if>
            <if test="maxSpeed != null">max_speed = #{maxSpeed},</if>
            <if test="wingspan != null">wingspan = #{wingspan},</if>
            <if test="weight != null">weight = #{weight},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            updated_at = #{updatedAt},
        </set>
        WHERE id = #{id} AND deleted = 0
    </update>

</mapper>
